# Required operator boundary. Use independent random values.
MARKETING_OPERATOR_TOKEN=
MARKETING_SESSION_SECRET=

# Optional Anthropic provider. Both values are required together.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Explicit non-AI development fallback.
MARKETING_DEMO_MODE=false

# Runtime controls
PORT=3000
MARKETING_TIMEOUT_MS=20000
MARKETING_SESSION_HOURS=8
MARKETING_MAX_REQUESTS=20
